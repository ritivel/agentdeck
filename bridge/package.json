{
  "name": "agentdeck-bridge",
  "version": "0.3.0",
  "description": "AgentDeck bridge daemon: control local coding agents (Claude Code, Cursor, Codex) from your phone",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ritivel/agentdeck.git",
    "directory": "bridge"
  },
  "homepage": "https://github.com/ritivel/agentdeck#readme",
  "keywords": ["claude-code", "cursor", "codex", "ai-agents", "remote-control", "ios"],
  "engines": {
    "node": ">=22.5"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "agentdeck": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && rm -rf dist/web && cp -R ../web dist/web",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/live.mjs && tsx test/hooks.mjs && tsx test/handoff.mjs && tsx test/wrapper.mjs",
    "prepublishOnly": "tsc",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
